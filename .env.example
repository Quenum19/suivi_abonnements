# ─────────────────────────────────────────────────────────────
#  Suivi des abonnements — exemple de configuration
#  Copie ce fichier en .env puis adapte les valeurs.
#  NE JAMAIS committer le vrai .env (il est ignoré par git).
# ─────────────────────────────────────────────────────────────

# Port d'écoute du serveur (API + frontend en production)
PORT=4000

# Fuseau horaire utilisé par le planificateur quotidien
TZ=Africa/Abidjan

# Base de données (SQLite par défaut, migrable vers PostgreSQL)
# SQLite :   file:./prisma/dev.db
# Postgres : postgresql://user:pass@host:5432/dbname?schema=public
DATABASE_URL="file:./prisma/dev.db"

# ── Authentification (comptes + organisations, multi-tenant) ──
# Secret de signature des sessions JWT. EN PROD : chaîne longue et aléatoire.
JWT_SECRET=dev-insecure-secret-change-me
# Cookie Secure (true derrière HTTPS, false en dev http local).
COOKIE_SECURE=false

# ── Planificateur de rappels ──────────────────────────────────
# Seuils (en jours avant l'échéance) qui déclenchent un rappel.
REMINDER_THRESHOLDS=30,7,1
# Heure quotidienne du check, format cron (min heure * * *). 08:00 par défaut.
REMINDER_CRON=0 8 * * *
# Activer le planificateur interne au démarrage du serveur
SCHEDULER_ENABLED=true

# ── Canal e-mail (SMTP via Nodemailer) ────────────────────────
# Passe EMAIL_ENABLED=true puis remplis le bloc SMTP de TON fournisseur.
# EMAIL_TO accepte plusieurs adresses séparées par des virgules.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # true uniquement pour le port 465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Suivi abonnements <noreply@example.com>"
EMAIL_TO=
#
# Exemples prêts à l'emploi (décommente le bloc voulu) :
#
# ▸ Gmail (nécessite la validation en 2 étapes + un "mot de passe d'application")
#   https://myaccount.google.com/apppasswords
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=ton.adresse@gmail.com
#   SMTP_PASS=xxxxxxxxxxxxxxxx        # mot de passe d'application (16 car.)
#   EMAIL_FROM="Suivi abonnements <ton.adresse@gmail.com>"
#
# ▸ Brevo (ex-Sendinblue) — offre gratuite, idéal pour de l'envoi fiable
#   https://app.brevo.com/settings/keys/smtp
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=xxxxxx@smtp-brevo.com
#   SMTP_PASS=ta-cle-smtp-brevo
#
# ▸ Outlook / Microsoft 365
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USER=ton.adresse@outlook.com
#   SMTP_PASS=ton-mot-de-passe

# ── Canal Webhook n8n (→ WhatsApp / email / agenda) ───────────
# POST JSON vers cette URL à chaque rappel. Payload :
#   { name, category, expiry, daysLeft, amount,
#     currency, frequency, responsible, whatsappTo }
# Dans n8n, branche un nœud "WhatsApp" (Cloud API / Twilio) sur ce webhook
# et route vers `responsible` ou `whatsappTo`. C'est ainsi qu'on reçoit les
# rappels sur WhatsApp sans coder de fournisseur en dur.
N8N_ENABLED=false
N8N_WEBHOOK_URL=
# Numéro WhatsApp par défaut (format international) transmis dans le payload.
WHATSAPP_TO=

# ── Frontend ──────────────────────────────────────────────────
# Base de l'API vue par le navigateur. Vide = même origine (prod).
VITE_API_BASE=
